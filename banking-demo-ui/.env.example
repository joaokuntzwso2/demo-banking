# WSO2 Identity Server 7.3 SPA application
VITE_IS_BASE_URL=https://localhost:9444
VITE_IS_CLIENT_ID=REPLACE_WITH_WSO2_IS_SPA_CLIENT_ID
VITE_REDIRECT_URL=http://localhost:5173
VITE_SIGN_OUT_REDIRECT_URL=http://localhost:5173

# WSO2 API Manager gateway in the demo-banking stack
VITE_APIM_BASE_URL=http://localhost:8280

# Set this only if the API was published in API Manager with an additional context.
# Examples: /banking-mi, /banking-mi/1.0.0, /demo-banking
VITE_BANKING_MI_CONTEXT=

# Agent endpoint. Default contract is OpenAI-compatible APIM AI API.
VITE_AGENT_CONTRACT=ai-adapter
VITE_AGENT_CHAT_URL=http://localhost:8280/v1/ai/omni_a2a/chat/completions

# Optional: use only for a dry run when WSO2 IS is unavailable.
# Keep false for the real Identity Server demo.
VITE_ENABLE_MOCK_AUTH=false
# VITE_MOCK_SCOPES=openid profile email banking:profile:read banking:accounts:read banking:cards:read agent:chat
